    given-names: Casey
    orcid: "https://orcid.org/0009-0009-3726-568X"
repository-code: "https://github.com/cyanheads/openfda-mcp-server"
license: Apache-2.0
keywords:
  - mcp
  - model-context-protocol
  - openfda
  - drug-safety
  - pharmacovigilance
  - regulatory-data
